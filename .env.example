# ─── Database (Supabase / PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/yoticketsafrica

# ─── PayNow Zimbabwe (Sandbox) ───────────────────────────────────────────────
# Get these from https://developers.paynow.co.zw after registering a merchant account
# Sandbox Integration ID is: 13  |  Key: 9c4d3ca0-4ed8-40ee-8e0f-f97fdda2878d
PAYNOW_INTEGRATION_ID=13
PAYNOW_INTEGRATION_KEY=9c4d3ca0-4ed8-40ee-8e0f-f97fdda2878d
PAYNOW_SANDBOX=true

# ─── Twilio (WhatsApp delivery) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio Sandbox WhatsApp number (test); replace with your approved Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Resend (Email delivery) ─────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=YoTicketsAfrica <tickets@yoticketsafrica.com>

# ─── Cloudflare R2 (PDF + QR image storage) ──────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=yoticketsafrica
R2_PUBLIC_URL=https://files.yoticketsafrica.com

# ─── QR Security ─────────────────────────────────────────────────────────────
# MUST be at least 32 random characters — never share or commit this
QR_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET

# ─── YSAMS Integration (music-bos on webzim.co.zw) ───────────────────────────
YSAMS_API_URL=https://yourdomain.co.zw/yor-api
YSAMS_API_KEY=REPLACE_WITH_SHARED_SECRET_FOR_YSAMS

# ─── App URLs ────────────────────────────────────────────────────────────────
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
